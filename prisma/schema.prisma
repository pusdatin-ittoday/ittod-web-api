generator client {
  provider = "prisma-client-js"
  output   = "app/generated/prisma/client"
}

generator dbml {
  provider = "prisma-dbml-generator"
  output   = "../docs"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model user {
  id                       String               @id
  email                    String               @unique(map: "user_email_unique")
  full_name                String
  birth_date               DateTime?
  pendidikan               pendidikan_enum?
  nama_sekolah             String?
  entry_source             String?
  phone_number             String?
  id_line                  String?
  id_discord               String?
  id_instagram             String?
  is_registration_complete Int                  @default(0)
  jenis_kelamin            jenis_kelamin_enum?
  ktm_key                  String?
  twibbon_key              String?
  created_at               DateTime             @default(now())
  updated_at               DateTime?
  announcements            event_announcement[]
  event_participants       event_participant[]
  media                    media[]
  team_members             team_member[]
  identity                 user_identity?

  @@map("user")
}

model user_identity {
  id                                 String                      @id
  email                              String                      @unique(map: "user_identity_email_unique")
  provider                           user_identity_provider_enum @default(basic)
  hash                               String?
  is_verified                        Int                         @default(0)
  verification_token                 String?
  verification_token_expiration      DateTime?
  password_recovery_token            String?
  password_recovery_token_expiration DateTime?
  refresh_token                      String?
  role                               user_identity_role_enum     @default(user)
  remember_token                     String?
  created_at                         DateTime                    @default(now())
  updated_at                         DateTime?
  event_staff                        event_staff[]
  user                               user                        @relation(fields: [id], references: [id])
  notifications                      notification[]

  @@map("user_identity")
}

model notification {
  id          String   @id
  user_id     String
  title       String
  message     String
  type        notification_type_enum @default(info)
  is_read     Int      @default(0)
  related_id  String?
  created_at  DateTime @default(now())
  user        user_identity @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notification")
}

enum notification_type_enum {
  info
  success
  warning
  error
}

model password_reset_tokens {
  email      String    @id
  token      String
  created_at DateTime?

  @@map("password_reset_tokens")
}

model sessions {
  id            String  @id
  user_id       String?
  ip_address    String?
  user_agent    String?
  payload       String
  last_activity Int

  @@index([last_activity], map: "sessions_last_activity_index")
  @@index([user_id], map: "sessions_user_id_index")
  @@map("sessions")
}

model event {
  id                             String                    @id
  title                          String
  description                    String
  guide_book_url                 String
  type                           event_type_enum
  price                          Int                       @default(0)
  contact_person1                String
  contact_person2                String?
  max_noncompetition_participant Int?
  is_active                      Unsupported("tinyint(1)") @default(dbgenerated("'1'"))
  requires_submission            Boolean                  @default(false)
  submissions                    competition_submission[]
  announcements                  event_announcement[]
  participants                   event_participant[]
  staff                          event_staff[]
  timelines                      event_timeline[]
  teams                          team[]

  @@map("event")
}

model media {
  id                String               @id
  uploader_id       String
  name              String               @unique(map: "media_name_unique")
  grouping          media_grouping_enum?
  type              media_type_enum
  url               String
  created_at        DateTime             @default(now())
  updated_at        DateTime             @default(now())
  uploader          user                 @relation(fields: [uploader_id], references: [id])
  team_payment      team[]               @relation("PaymentProof")
  team_member_kartu team_member[]

  @@map("media")
}

model team {
  id                   String                   @id
  competition_id       String
  team_name            String
  team_code            String                   @unique(map: "team_team_code_unique")
  max_member           Int                      @default(3)
  is_document_verified Int                      @default(0)
  is_verified          Int                      @default(0)
  verification_error   String?
  created_at           DateTime                 @default(now())
  updated_at           DateTime?
  payment_proof_id     String?
  submissions          competition_submission[]
  payment_proof        media?                   @relation("PaymentProof", fields: [payment_proof_id], references: [id])
  competition          event                    @relation(fields: [competition_id], references: [id])
  members              team_member[]

  @@map("team")
}

model team_member {
  user_id            String
  team_id            String
  role               team_member_role_enum
  verification_error String?
  kartu_id           String?
  kartu              media?                @relation(fields: [kartu_id], references: [id])
  team               team                  @relation(fields: [team_id], references: [id])
  user               user                  @relation(fields: [user_id], references: [id])

  @@id([user_id, team_id])
  @@map("team_member")
}

model event_timeline {
  id       String   @id
  event_id String
  title    String
  date     DateTime
  event    event    @relation(fields: [event_id], references: [id])

  @@map("event_timeline")
}

model event_announcement {
  id          String   @id
  event_id    String
  author_id   String
  title       String
  description String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  author      user     @relation(fields: [author_id], references: [id])
  event       event    @relation(fields: [event_id], references: [id])

  @@map("event_announcement")
}

model competition_submission {
  team_id           String
  competition_id    String
  created_at        DateTime  @default(now())
  updated_at        DateTime?
  submission_object String?
  competition       event     @relation(fields: [competition_id], references: [id])
  team              team      @relation(fields: [team_id], references: [id])

  @@id([team_id, competition_id])
  @@map("competition_submission")
}

model event_participant {
  user_id              String
  event_id             String
  date_added           DateTime                  @default(now())
  payment_proof        String?
  payment_verification payment_verification_enum @default(pending)
  event                event                     @relation(fields: [event_id], references: [id])
  user                 user                      @relation(fields: [user_id], references: [id])

  @@id([user_id, event_id])
  @@map("event_participant")
}

model event_staff {
  event_id   String
  user_id    String
  created_at DateTime?
  updated_at DateTime?
  user       user_identity @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event      event         @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@id([event_id, user_id])
  @@map("event_staff")
}

model cache {
  key        String @id
  value      String
  expiration Int

  @@index([expiration], map: "cache_expiration_index")
}

model cache_locks {
  key        String @id
  owner      String
  expiration Int

  @@index([expiration], map: "cache_locks_expiration_index")
}

model failed_jobs {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique(map: "failed_jobs_uuid_unique")
  connection String
  queue      String
  payload    String
  exception  String
  failed_at  DateTime @default(now())
}

model job_batches {
  id             String  @id
  name           String
  total_jobs     Int
  pending_jobs   Int
  failed_jobs    Int
  failed_job_ids String
  options        String?
  cancelled_at   Int?
  created_at     Int
  finished_at    Int?
}

model jobs {
  id           Int    @id @default(autoincrement())
  queue        String
  payload      String
  attempts     Int
  reserved_at  Int?
  available_at Int
  created_at   Int

  @@index([queue], map: "jobs_queue_index")
}

model migrations {
  id        Int    @id @default(autoincrement())
  migration String
  batch     Int
}

enum pendidikan_enum {
  sma
  s1
  d3
  d4
}

enum team_member_role_enum {
  leader
  member
}

enum user_identity_provider_enum {
  google
  basic
  github
}

enum payment_verification_enum {
  pending
  accepted
  rejected
}

enum user_identity_role_enum {
  superadmin
  admin_keuangan
  panitia
  user
}

enum media_grouping_enum {
  payments
  dokum_tahun_lalu
  competition_submission
  twibbon
}

enum media_type_enum {
  image
  pdf
}

enum event_type_enum {
  competition
  non_competition
}

enum jenis_kelamin_enum {
  laki2
  perempuan
}

enum bundling_enum {
  day1
  day2
  day1_day2
}
