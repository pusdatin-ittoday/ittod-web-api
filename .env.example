# App URLs
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
APP_FRONTEND_URL=http://localhost:5173

# Comma-separated origins allowed by CORS
CORS_ORIGINS=http://localhost:5173

# Database and session
# Path ke database SQLite dari Laravel admin project
# Untuk development, gunakan path relatif dari folder ittod-web
# Untuk production, gunakan absolute path
DATABASE_URL="file:../dashboard-ittod-admin/database/database.sqlite"
SECRET_KEY_SESSION=replace-with-a-long-random-secret

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT=http://localhost:3000/api/auth/google/redirect

# SMTP
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=replace-with-email-user
EMAIL_PASS=replace-with-email-password
EMAIL_SENDER="IT Today <no-reply@example.com>"
SUPPORT_EMAIL=support@example.com

# Cloudflare R2
R2_LINK=https://replace-with-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET_NAME=ittoday
R2_PUBLIC=https://replace-with-public-r2-domain
